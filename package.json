{
  "name": "contexa-cli",
  "version": "1.0.0",
  "description": "Contexa CLI - AI-Native Zero Trust Security for Spring Boot",
  "main": "src/index.js",
  "bin": {
    "contexa": "src/index.js"
  },
  "files": [
    "src/",
    "sea-config.json",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contexa-security/contexa-cli.git"
  },
  "homepage": "https://docs.ctxa.ai/",
  "bugs": {
    "url": "https://github.com/contexa-security/contexa-cli/issues"
  },
  "keywords": [
    "contexa",
    "spring-boot",
    "zero-trust",
    "ai-security",
    "cli"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "start": "node src/index.js",
    "test": "node --test",
    "bundle": "esbuild src/index.js --bundle --platform=node --target=node18 --outfile=dist/bundle.js --format=cjs",
    "build": "npm run bundle && node --experimental-sea-config sea-config.json"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "fs-extra": "^11.1.1",
    "inquirer": "^8.2.6",
    "js-yaml": "^4.1.1",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "esbuild": "^0.20.0"
  }
}
